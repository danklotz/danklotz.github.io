      <pubDate>Sat, 09 Dec 2017 00:00:00 +0000</pubDate>
      
      <guid>/2017/12/09/sketch-function-plotting/</guid>
      <description>&lt;div id=&#34;sketch-holder&#34; align =&#34;justify&#34;&gt;&lt;/div&gt;

&lt;script src=&#34;../../p5.js&#34;&gt;&lt;/script&gt;
&lt;script&gt;
// actual script ---------------------------------------------------------------
var c_size = 450
var midpoint = 0.5*c_size;
var resolution = 10;
var x1 = 0;
var y1 = 0;
var grid_div = 15;



function setup() {
  background(&#34;#DDDCD3&#34;);
  var canvas = createCanvas(c_size, c_size);
