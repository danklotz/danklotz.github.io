  strokeWeight(2);
  noFill();
  beginShape();
    for (var i=0; i&lt;=c_size; i++) {
      x1 = c_size - i;
      y1 = midpoint - 0.02*(i-midpoint)**2 + 150;
      curveVertex(x1,y1);
    }
  endShape();
}

function f2() {
  stroke(100,100,100);
  strokeWeight(2);
  noFill();
  beginShape();
    for (var i=0; i&lt;=c_size; i++) {
      x1 = c_size - i;
      y1 = midpoint + 0.5*(i-midpoint);
      curveVertex(x1,y1);
    }
  endShape();
}

function f_fuse() {
  stroke(30,144,255,120);
  strokeWeight(5);
  noFill();
  beginShape();
    for (var i=0; i&lt;=c_size; i++) {
      x1 = c_size - i;
      y1 = max(midpoint + 0.5*(i-midpoint),midpoint - 0.02*(i-midpoint)**2 + 150);
      curveVertex(x1,y1);
    }
  endShape();
}

