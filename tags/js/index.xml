    <item>
      <title>p5js: Doodle Flower</title>
      <link>/note/2017/12/p5js-doodle-flower/</link>
      <pubDate>Fri, 01 Dec 2017 00:00:00 +0000</pubDate>
      
      <guid>/note/2017/12/p5js-doodle-flower/</guid>
      <description>&lt;p&gt;A little doodle with p5.js
&lt;div id=&#34;sketch-holder&#34; align =&#34;center&#34;&gt;&lt;/div&gt;&lt;/p&gt;

&lt;p&gt;Code:&lt;/p&gt;

&lt;pre&gt;&lt;code class=&#34;language-js&#34;&gt;var c_size = 450
var midpoint = 0.5*c_size;
var c_pad = c_size - 20
var alpha_decay = 20
var easing = 0.03;
var x = midpoint
var y = midpoint

var red = 30
var green = 144
var blue = 255

var update_time = 0
var update_step = 100

function setup() {
  background(&amp;quot;#EBEBEB&amp;quot;);
  var canvas = createCanvas(c_size, c_size);
  canvas.parent(&#39;sketch-holder&#39;);

}

function mousePressed() {
  red = 30
  green = 144
  blue = 255
}

function draw() {

  if (frameCount &amp;gt; update_time) {
    update_time += update_step
    red = round( random(1,244) )
    green = round( random(1,244) )
    blue = round( random(1,244) )
  }

  //square
  stroke(&amp;quot;#EBEBEB&amp;quot;)
  fill(&amp;quot;#EBEBEB&amp;quot;)
  rect(0,0,c_size-1,c_size-1);
  // outer circles
  fill(&amp;quot;#fff&amp;quot;);
  stroke(&amp;quot;#fff&amp;quot;)
  ellipse(0,0,c_size,c_size);
  ellipse(0,c_size,c_size,c_size);
  ellipse(c_size,0,c_size,c_size);
  ellipse(c_size,c_size,c_size,c_size);
  // line
  stroke(red, green, blue);
  line(midpoint, midpoint, x, y)
  // cicrles 1
  fill(red, green, blue);
  stroke(red, green, blue);
    ellipse(midpoint,
            midpoint,
            c_pad/6,
            c_pad/6);
    ellipse(x, y, 25, 25);
    ellipse(0.5*(midpoint+x),
            0.5*(midpoint+y),
            c_pad/8,
            c_pad/8);
  fill(221, 220, 211, 0);
  strokeWeight(3);
  stroke(red, green, blue, 255-alpha_decay);
    ellipse(0.65*midpoint + 0.35*x,
            0.65*midpoint + 0.35*y,
            c_pad/4,
            c_pad/4);
  stroke(red, green, blue, 255 - 2*alpha_decay);
    ellipse(0.8*midpoint + 0.2*x,
            0.8*midpoint + 0.2*y,
            c_pad/3,
            c_pad/3);
  stroke(red, green, blue, 255 - 4*alpha_decay);
    ellipse(0.9*midpoint + 0.1*x,
            0.9*midpoint + 0.1*y,
            c_pad/2,
            c_pad/2);
  stroke(red, green, blue, 255 - 6*alpha_decay);
    ellipse(0.95*midpoint + 0.05*x,
            0.95*midpoint + 0.05*y,
            c_pad,
            c_pad);
  // ellipses 1
  strokeWeight(1);
    ellipse(midpoint, midpoint, c_pad/3, c_pad/4);
    ellipse(midpoint, midpoint, c_pad/4, c_pad/3);
    ellipse(midpoint, midpoint, c_pad/2, c_pad/3);
    ellipse(midpoint, midpoint, c_pad/3, c_pad/2);
    ellipse(midpoint, midpoint, c_pad  , c_pad/2);
    ellipse(midpoint, midpoint, c_pad/2, c_pad  );
  // cicles 2
  strokeWeight(2);
  stroke(red, green, blue, 255 - 8*alpha_decay);
    ellipse(0, midpoint, c_size, c_size);
    ellipse(c_size, midpoint, c_size, c_size);
    ellipse(midpoint, 0, c_size, c_size);
    ellipse(midpoint, c_size, c_size, c_size);
  // update position
  x += (mouseX - x) * easing;
  y += (mouseY - y) * easing;

}
&lt;/code&gt;&lt;/pre&gt;

&lt;script src=&#34;https://cdnjs.cloudflare.com/ajax/libs/p5.js/0.5.16/p5.js&#34;&gt;&lt;/script&gt;
&lt;script&gt;
// actual script ---------------------------------------------------------------
var c_size = 450
var midpoint = 0.5*c_size;
var c_pad = c_size - 20
var alpha_decay = 20
var easing = 0.03;
var x = midpoint
var y = midpoint

var red = 30
var green = 144
var blue = 255

var update_time = 0
var update_step = 100

function setup() {
  background(&#34;#EBEBEB&#34;);
  var canvas = createCanvas(c_size, c_size);
  canvas.parent(&#39;sketch-holder&#39;);

}

function mousePressed() {
  red = 30
  green = 144
  blue = 255
}

function draw() {

  if (frameCount &gt; update_time) {
    update_time += update_step
    red = round( random(1,244) )
    green = round( random(1,244) )
    blue = round( random(1,244) )
  }

  //square
  stroke(&#34;#EBEBEB&#34;)
  fill(&#34;#EBEBEB&#34;)
  rect(0,0,c_size-1,c_size-1);
  // outer circles
  fill(&#34;#fff&#34;);
  stroke(&#34;#fff&#34;)
  ellipse(0,0,c_size,c_size);
  ellipse(0,c_size,c_size,c_size);
  ellipse(c_size,0,c_size,c_size);
  ellipse(c_size,c_size,c_size,c_size);
  // line
  stroke(red, green, blue);
  line(midpoint, midpoint, x, y)
  // cicrles 1
  fill(red, green, blue);
  stroke(red, green, blue);
    ellipse(midpoint,
            midpoint,
            c_pad/6,
            c_pad/6);
    ellipse(x, y, 25, 25);
    ellipse(0.5*(midpoint+x),
            0.5*(midpoint+y),
            c_pad/8,
            c_pad/8);
  fill(221, 220, 211, 0);
  strokeWeight(3);
  stroke(red, green, blue, 255-alpha_decay);
    ellipse(0.65*midpoint + 0.35*x,
            0.65*midpoint + 0.35*y,
            c_pad/4,
            c_pad/4);
  stroke(red, green, blue, 255 - 2*alpha_decay);
    ellipse(0.8*midpoint + 0.2*x,
            0.8*midpoint + 0.2*y,
            c_pad/3,
            c_pad/3);
  stroke(red, green, blue, 255 - 4*alpha_decay);
    ellipse(0.9*midpoint + 0.1*x,
            0.9*midpoint + 0.1*y,
            c_pad/2,
            c_pad/2);
  stroke(red, green, blue, 255 - 6*alpha_decay);
    ellipse(0.95*midpoint + 0.05*x,
            0.95*midpoint + 0.05*y,
            c_pad,
            c_pad);
  // ellipses 1
  strokeWeight(1);
    ellipse(midpoint, midpoint, c_pad/3, c_pad/4);
    ellipse(midpoint, midpoint, c_pad/4, c_pad/3);
    ellipse(midpoint, midpoint, c_pad/2, c_pad/3);
    ellipse(midpoint, midpoint, c_pad/3, c_pad/2);
    ellipse(midpoint, midpoint, c_pad  , c_pad/2);
    ellipse(midpoint, midpoint, c_pad/2, c_pad  );
  // cicles 2
  strokeWeight(2);
  stroke(red, green, blue, 255 - 8*alpha_decay);
    ellipse(0, midpoint, c_size, c_size);
    ellipse(c_size, midpoint, c_size, c_size);
    ellipse(midpoint, 0, c_size, c_size);
    ellipse(midpoint, c_size, c_size, c_size);
  // update position
  x += (mouseX - x) * easing;
  y += (mouseY - y) * easing;

}
&lt;/script&gt;
</description>
